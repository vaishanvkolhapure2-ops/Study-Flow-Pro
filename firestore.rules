rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Default Deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions (The Primitives)
    // ===============================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // Validation Blueprints (The "Anti-Update-Gap")
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.keys().size() <= 6 &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() < 256 &&
             data.role in ['student', 'admin'] &&
             data.createdAt == request.time;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['uid', 'text', 'completed', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.uid == request.auth.uid &&
             data.text is string && data.text.size() > 0 && data.text.size() < 500 &&
             data.completed is bool &&
             data.createdAt == request.time;
    }

    function isValidStudyPlan(data) {
      return data.keys().hasAll(['uid', 'subjects', 'days', 'plan', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.subjects is string && data.subjects.size() < 1000 &&
             data.days is int && data.days > 0 &&
             data.plan is string && data.plan.size() < 10000 &&
             data.createdAt == request.time;
    }

    function isValidChatMessage(data) {
      return data.keys().hasAll(['uid', 'role', 'content', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.uid == request.auth.uid &&
             data.role in ['user', 'ai'] &&
             data.content is string && data.content.size() > 0 && data.content.size() < 5000 &&
             data.createdAt == request.time;
    }

    function isValidEducationalVideo(data) {
      return data.keys().hasAll(['uid', 'title', 'prompt', 'videoUri', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.title is string && data.title.size() < 200 &&
             data.prompt is string && data.prompt.size() < 2000 &&
             data.videoUri is string && data.videoUri.size() < 1000 &&
             (!('summary' in data) || (data.summary is string && data.summary.size() < 5000)) &&
             data.createdAt == request.time;
    }

    // ===============================================================
    // Resource Rules (The Fortress)
    // ===============================================================

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Users cannot list other users
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        // Action: Update Profile
        incoming().diff(existing()).affectedKeys().hasOnly(['email', 'displayName', 'photoURL'])
      );
    }

    match /tasks/{taskId} {
      allow get: if isSignedIn() && existing().uid == request.auth.uid;
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && isValidId(taskId) && isValidTask(incoming());
      allow update: if isOwner(existing().uid) && isValidTask(incoming()) && (
        // Action: Toggle completion or edit text
        incoming().diff(existing()).affectedKeys().hasOnly(['text', 'completed'])
      );
      allow delete: if isOwner(existing().uid);
    }

    match /studyPlans/{planId} {
      allow get: if isSignedIn() && existing().uid == request.auth.uid;
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && isValidId(planId) && isValidStudyPlan(incoming());
      allow update: if isOwner(existing().uid) && isValidStudyPlan(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['plan', 'fullPlan'])
      );
      allow delete: if isOwner(existing().uid);
    }

    match /chatMessages/{messageId} {
      allow get: if isSignedIn() && existing().uid == request.auth.uid;
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && isValidId(messageId) && isValidChatMessage(incoming());
      allow update: if false; // Immutability Enforced
      allow delete: if isOwner(existing().uid);
    }

    match /educationalVideos/{videoId} {
      allow get: if isSignedIn() && existing().uid == request.auth.uid;
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && isValidId(videoId) && isValidEducationalVideo(incoming());
      allow update: if isOwner(existing().uid) && isValidEducationalVideo(incoming()) && (
        // Action: Add AI Summary
        incoming().diff(existing()).affectedKeys().hasOnly(['summary'])
      );
      allow delete: if isOwner(existing().uid);
    }
  }
}
